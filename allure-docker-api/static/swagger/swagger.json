{
   "openapi":"3.0.0",
   "info":{
      "description":"HTTP API do Allure Docker Service. Os relatórios HTML são gerados no servidor com **Allure Report 3** (pacote npm `allure`).\n\n**Base URL:** `{scheme}://{host}:{port}/allure-docker-service` — ex.: `http://localhost:5050/allure-docker-service` (porta do contentor) ou a porta mapeada no host (ex.: `7272` no compose).\n\n**Documentação interativa:** `GET /allure-docker-service/swagger` (ou `/swagger` na raiz).\n\n**Segurança (`SECURITY_ENABLED=1`):** `POST /allure-docker-service/login` com JSON `{\"username\": \"...\", \"password\": \"...\"}`; a resposta define cookies de sessão. Operações protegidas exigem CSRF: cabeçalho `X-CSRF-TOKEN` com o valor do cookie `csrf_access_token` (ou fluxo equivalente). Endpoints públicos incluem `GET /version` e `GET /swagger.json`.\n\n**Fluxo típico:** (1) `POST /projects` se precisar de projeto; (2) `POST /send-results` com ficheiros gerados pelo adaptador Allure (pasta `allure-results`); (3) `GET /generate-report?project_id=...`; (4) abrir relatório em `/projects/{id}/reports/...`.\n\n**Créditos:** fork mantido por Flavio Ramos (flavior.desouza@gmail.com, https://github.com/LFBRxD). Projeto original por Frank Escobar (fescobar.systems@gmail.com, https://github.com/fescobar/allure-docker-service).\n\nReferência Allure Report 3: https://allurereport.org/docs/",
      "version":"3.0.0",
      "title":"Allure Docker Service API",
      "contact":{
         "name":"Flavio Ramos (mantenedor deste fork)",
         "url":"https://github.com/LFBRxD/allure-docker-service",
         "email":"flavior.desouza@gmail.com"
      },
      "license":{
         "name":"Apache-2.0",
         "url":"https://www.apache.org/licenses/LICENSE-2.0"
      }
   },
   "servers":[
      {
         "url":"/allure-docker-service",
         "description":"Prefixo relativo ao host (use com Try it out no Swagger UI)"
      },
      {
         "url":"http://127.0.0.1:5050/allure-docker-service",
         "description":"Exemplo: API na porta 5050 do contentor"
      }
   ],
   "tags":[
      {
         "name":"Info",
         "description":"Versão, Swagger e especificação OpenAPI"
      },
      {
         "name":"Action",
         "description":"Enviar resultados, gerar relatório (Allure 3), limpar dados, relatório emailable"
      },
      {
         "name":"Project",
         "description":"CRUD de projetos e ficheiros estáticos do relatório"
      }
   ],
   "paths":{
      "/version":{
         "get":{
            "tags":[
               "Info"
            ],
            "summary":"Versão do CLI Allure Report (npm `allure`)",
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/swagger":{
         "get":{
            "tags":[
               "Info"
            ],
            "summary":"Interface Swagger UI",
            "responses":{
               "200":{
                  "description":"OK"
               }
            }
         }
      },
      "/swagger.json":{
         "get":{
            "tags":[
               "Info"
            ],
            "summary":"Especificação OpenAPI (JSON)",
            "responses":{
               "200":{
                  "description":"OK"
               }
            }
         }
      },
      "/config":{
         "get":{
            "tags":[
               "Action"
            ],
            "summary":"Obter configuração em tempo de execução (JWT se segurança ativa)",
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/latest-report":{
         "get":{
            "tags":[
               "Action"
            ],
            "summary":"Redirecionar para o relatório HTML mais recente do projeto",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/send-results":{
         "post":{
            "tags":[
               "Action"
            ],
            "summary":"Enviar ficheiros de resultados (JSON base64 ou multipart)",
            "consumes":[
               "application/json",
               "multipart/form-data"
            ],
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               },
               {
                  "in":"query",
                  "name":"force_project_creation",
                  "schema":{
                     "type":"string"
                  },
                  "value": "false"
               }
            ],
            "requestBody":{
               "description":"Files to send",
               "required":"true",
               "content":{
                  "application/json":{
                     "schema":{
                        "$ref":"#/components/schemas/results"
                     },
                     "example":{
                        "results":[
                           {
                              "file_name":"example1",
                              "content_base64":"Y29udGVudCBleGFtcGxlMQ=="
                           },
                           {
                              "file_name":"example2",
                              "content_base64":"Y29udGVudCBleGFtcGxlMg=="
                           },
                           {
                              "file_name":"example3",
                              "content_base64":"Y29udGVudCBleGFtcGxlMw=="
                           }
                        ]
                     }
                  },
                  "multipart/form-data":{
                     "schema":{
                        "$ref":"#/components/schemas/files"
                     }
                  }
               }
            },
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/generate-report":{
         "get":{
            "tags":[
               "Action"
            ],
            "summary":"Gerar relatório (executa Allure Report 3 sobre os resultados do projeto)",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               },
               {
                  "in":"query",
                  "name":"execution_name",
                  "schema":{
                     "type":"string"
                  }
               },
               {
                  "in":"query",
                  "name":"execution_from",
                  "schema":{
                     "type":"string"
                  }
               },
               {
                  "in":"query",
                  "name":"execution_type",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/clean-results":{
         "delete":{
            "tags":[
               "Action"
            ],
            "summary":"Limpar resultados armazenados do projeto",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/clean-history":{
         "delete":{
            "tags":[
               "Action"
            ],
            "summary":"Limpar histórico e tendências do projeto",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/emailable-report/render":{
         "get":{
            "tags":[
               "Action"
            ],
            "summary":"Renderizar relatório emailable (HTML)",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/emailable-report/export":{
         "get":{
            "tags":[
               "Action"
            ],
            "summary":"Exportar relatório emailable (download)",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/report/export":{
         "get":{
            "tags":[
               "Action"
            ],
            "summary":"Exportar relatório completo (ZIP, saída Allure Report 3)",
            "parameters":[
               {
                  "in":"query",
                  "name":"project_id",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/projects":{
         "post":{
            "tags":[
               "Project"
            ],
            "summary":"Criar projeto",
            "consumes":[
               "application/json"
            ],
            "requestBody":{
               "required":"true",
               "content":{
                  "application/json":{
                     "schema":{
                        "$ref":"#/components/schemas/project"
                     },
                     "example":{
                        "id":"my-project-id"
                     }
                  }
               }
            },
            "produces":[
               "application/json"
            ],
            "responses":{
               "201":{
                  "description":"CREATED",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         },
         "get":{
            "tags":[
               "Project"
            ],
            "summary":"Listar projetos",
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/projects/{id}":{
         "delete":{
            "tags":[
               "Project"
            ],
            "summary":"Eliminar projeto",
            "parameters":[
               {
                  "in":"path",
                  "name":"id",
                  "value":"my-project-id",
                  "schema":{
                     "type":"string"
                  },
                  "required":"true"
               }
            ],
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         },
         "get":{
            "tags":[
               "Project"
            ],
            "summary":"Obter metadados do projeto",
            "parameters":[
               {
                  "in":"path",
                  "name":"id",
                  "value":"my-project-id",
                  "schema":{
                     "type":"string"
                  },
                  "required":"true"
               }
            ],
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/projects/{id}/reports/{path}":{
         "get":{
            "tags":[
               "Project"
            ],
            "summary":"Servir ficheiros estáticos do relatório ou redirecionar",
            "parameters":[
               {
                  "in":"path",
                  "name":"id",
                  "value":"my-project-id",
                  "schema":{
                     "type":"string"
                  },
                  "required":"true"
               },
               {
                  "in":"path",
                  "name":"path",
                  "value":"my-path",
                  "schema":{
                     "type":"string"
                  },
                  "required":"true"
               },
               {
                  "in":"query",
                  "name":"redirect",
                  "value":"false",
                  "schema":{
                     "type":"string"
                  }
               }
            ],
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/projects/search":{
         "get":{
            "tags":[
               "Project"
            ],
            "summary":"Pesquisar projeto por id",
            "parameters":[
               {
                  "in":"query",
                  "name":"id",
                  "value":"my-project-id",
                  "schema":{
                     "type":"string"
                  },
                  "required":"true"
               }
            ],
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/projects/storage":{
         "get":{
            "tags":[
               "Project"
            ],
            "summary":"Uso de disco (todos os projetos)",
            "description":"Devolve `total_bytes` e `total_human`; por `project_id`, devolve `bytes_total`, `bytes_total_human`, `bytes_results`, `bytes_results_human`, `bytes_reports` e `bytes_reports_human`.",
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      },
      "/projects/{id}/storage":{
         "get":{
            "tags":[
               "Project"
            ],
            "summary":"Uso de disco (um projeto)",
            "description":"Devolve `path`, `bytes_total`, `bytes_total_human`, `bytes_results`, `bytes_results_human`, `bytes_reports` e `bytes_reports_human`.",
            "parameters":[
               {
                  "in":"path",
                  "name":"id",
                  "value":"my-project-id",
                  "schema":{
                     "type":"string"
                  },
                  "required":"true"
               }
            ],
            "produces":[
               "application/json"
            ],
            "responses":{
               "200":{
                  "description":"OK",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "400":{
                  "description":"BAD_REQUEST",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               },
               "404":{
                  "description":"NOT_FOUND",
                  "schema":{
                     "$ref":"#/components/schemas/response"
                  }
               }
            }
         }
      }
   },
   "components":{
      "schemas":{
         "data":{
            "properties":{
               "xxx":{
                  "type":"object"
               }
            }
         },
         "meta_data":{
            "properties":{
               "message":{
                  "type":"string"
               }
            }
         },
         "response":{
            "type":"object",
            "properties":{
               "data":{
                  "type":"object",
                  "additionalProperties":{
                     "$ref":"#/components/schemas/data"
                  }
               },
               "meta_data":{
                  "type":"object",
                  "additionalProperties":{
                     "$ref":"#/components/schemas/meta_data"
                  }
               }
            }
         },
         "results":{
            "type":"object",
            "properties":{
               "results":{
                  "$ref":"#/components/schemas/result"
               }
            }
         },
         "result":{
            "type":"array",
            "items":{
               "type":"object",
               "properties":{
                  "file_name":{
                     "type":"string"
                  },
                  "content_base64":{
                     "type":"string"
                  }
               }
            }
         },
         "project":{
            "type":"object",
            "properties":{
               "id":{
                  "type":"string"
               }
            }
         },
         "files":{
            "type":"object",
            "properties":{
               "files[]":{
                  "type":"array",
                  "items":{
                     "type":"string",
                     "format":"binary"
                  }
               }
            }
         }
      }
   }
}